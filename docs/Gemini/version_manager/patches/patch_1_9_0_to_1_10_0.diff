--- version_manager_v1_9_0.sh	2026-06-04 22:12:35.924854929 +0300
+++ version_manager_v1_10_0.sh	2026-06-04 22:23:22.919988251 +0300
@@ -1,7 +1,7 @@
 #!/bin/bash
 
 # Project Version Management Script
-# Version: 1.9.0
+# Version: 1.10.0
 # Usage:
 #   ./manage_versions.sh diff      - Create patches, keep latest
 #   ./manage_versions.sh restore   - Interactively select version to restore to ./restored
@@ -11,9 +11,37 @@
 
 set -e
 
-SCRIPT_VERSION="1.9.0"
+SCRIPT_VERSION="1.10.0"
+
+# Determine PROJECT_NAME: Environment Var > .version_manager file > Default "converter"
+if [ -z "$PROJECT_NAME" ] && [ -f ".version_manager" ]; then
+    while IFS= read -r line || [ -n "$line" ]; do
+        # Pure Bash trim leading/trailing whitespace
+        line="${line#"${line%%[![:space:]]*}"}"
+        line="${line%"${line##*[![:space:]]}"}"
+        
+        # Skip empty lines and comment lines
+        [[ -z "$line" ]] && continue
+        [[ "$line" =~ ^# ]] && continue
+
+        # Check if line is formatted as PROJECT_NAME=value
+        if [[ "$line" =~ ^PROJECT_NAME[[:space:]]*=[[:space:]]*(.*) ]]; then
+            val="${BASH_REMATCH[1]}"
+            # Strip potential surrounding quotes
+            val="${val#\"}"
+            val="${val%\"}"
+            val="${val#\'}"
+            val="${val%\'}"
+            PROJECT_NAME="$val"
+            break
+        else
+            # If it's just a raw name, treat the first valid line as the project name
+            PROJECT_NAME="$line"
+            break
+        fi
+    done < ".version_manager"
+fi
 
-# Read project name from environment variable; default to generic "converter" if not set
 PROJECT_NAME="${PROJECT_NAME:-converter}"
 
 echo "Using Project Name: $PROJECT_NAME"
