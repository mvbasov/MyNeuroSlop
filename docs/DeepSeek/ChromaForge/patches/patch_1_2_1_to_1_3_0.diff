+    // ----- Export / Import functionality -----
+    function copyCssToClipboard() {
+        const theme = getCurrentPreviewTheme();
+        const cssString = `:root {\n  --primary: ${theme.primary};\n  --secondary: ${theme.secondary};\n  --bg-color: ${theme.bgColor};\n  --surface-color: ${theme.surfaceColor};\n  --text-color: ${theme.textColor};\n  --border-color: ${theme.borderColor};\n}`;
+        navigator.clipboard.writeText(cssString).then(() => showToast("✅ CSS copied to clipboard!", "info")).catch(() => showToast("❌ Failed to copy", "error"));
+    }
+    function exportToJson() {
+        const theme = getCurrentPreviewTheme();
+        const dataStr = JSON.stringify(theme, null, 2);
+        const blob = new Blob([dataStr], {type: "application/json"});
+        const url = URL.createObjectURL(blob);
+        const a = document.createElement('a');
+        a.href = url;
+        a.download = `chromaforge_theme_${Date.now()}.json`;
+        document.body.appendChild(a);
+        a.click();
+        document.body.removeChild(a);
+        URL.revokeObjectURL(url);
+        showToast("💾 Theme exported as JSON", "info");
+    }
+    function importFromJson(file) {
+        const reader = new FileReader();
+        reader.onload = (e) => {
+            try {
+                const theme = JSON.parse(e.target.result);
+                // validate required fields
+                const required = ['primary','secondary','bgColor','surfaceColor','textColor','borderColor'];
+                if(required.every(k => theme[k] && /^#[0-9A-Fa-f]{6}$/.test(theme[k]))) {
+                    applyPreviewTheme(theme);
+                    showToast("📂 Theme imported successfully", "info");
+                } else {
+                    showToast("❌ Invalid theme file: missing or malformed hex colors", "error");
+                }
+            } catch(err) {
+                showToast("❌ Failed to parse JSON", "error");
+            }
+        };
+        reader.readAsText(file);
+    }
+    const copyBtn = document.getElementById('copyCssBtn');
+    const exportBtn = document.getElementById('exportJsonBtn');
+    const importBtn = document.getElementById('importJsonBtn');
+    const fileInput = document.getElementById('jsonFileInput');
+    if(copyBtn) copyBtn.addEventListener('click', copyCssToClipboard);
+    if(exportBtn) exportBtn.addEventListener('click', exportToJson);
+    if(importBtn) importBtn.addEventListener('click', () => fileInput.click());
+    if(fileInput) fileInput.addEventListener('change', (e) => { if(e.target.files[0]) importFromJson(e.target.files[0]); e.target.value = ''; });
